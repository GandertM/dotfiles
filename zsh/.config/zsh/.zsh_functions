command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# ~~~~~~~~~~~~~~~~~~~~~~~~~~ Update ~~~~~~~~~~~~~~~~~~~~~~~~

update_opensuse() {
    
    # Detect openSUSE variant
    if [[ -f /etc/os-release ]]; then
        source /etc/os-release
        echo "➡️ Detected: $PRETTY_NAME"
    else
        echo "❌ Could not detect openSUSE version."
        return 1
    fi

    # Refreshing repositories
    sudo zypper ref

    # Only run dist-upgrade (dup) on Slowroll or Tumbleweed
    if echo "$ID" | grep -qiE 'tumbleweed|slowroll'; then
        sudo zypper dup
    else
        sudo zypper up
    fi

}

update() {

  # define timestamp file
  STAMP_FILE="$HOME/.ts_update.ts"
  
  # use interval of 1 week
  INTERVAL="604800"   

  # if timestamp file does not exist, create it
  [[ ! -f $STAMP_FILE ]] && touch $STAMP_FILE

  # determine times and delta
  STAMP="$(date -r $STAMP_FILE +%s 2>/dev/null)"
  NOW="$(date +%s 2>/dev/null)"
  DELTA=$(($NOW-$STAMP))

  #line_blue
  draw_line "blue"

  #text_color "Cyan" "UPDATE SYSTEM"
  print_colored_text "green" "UPDATE SYSTEM"

  #update_system
  update_opensuse
  
  #line_blue
  draw_line "blue"

  #text_color "Cyan" "UPDATE FLATPAK"
  print_colored_text "green" "UPDATE FLATPAK"

  flatpak --user uninstall --unused
  flatpak --user update
      
  #line_blue
  draw_line "blue"
  
  # if time has passed, execute
  if [[ $DELTA -ge $INTERVAL ]]; then
    
    #text_color "Cyan" "UPDATE FLATPAK"
    print_colored_text "green" "REPAIR FLATPAK"

	  flatpak --user repair

    #line_blue
    draw_line "blue"
    
    #text_color "Cyan" "UPDATE ZINIT"
    print_colored_text "green" "UPDATE ZINIT"

    zinit self-update && zinit update

    #line_blue
    draw_line "blue"

    touch $STAMP_FILE

  fi
        
}

