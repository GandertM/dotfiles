# ~~~~~~~~~~~~~~~~~~~~~~~~~~ Other ~~~~~~~~~~~~~~~~~~~~~~~~

cheatsh() {

  # Ask cheat.sh website for details about a Linux command.
  curl -m 10 "http://cheat.sh/${1}" 2>/dev/null || printf '%s\n' "[ERROR] Something broke"

}

flocate() {

  # locate file, but exclude snapshots
  if [ -z "$1" ]
  then
    printf "You need to add a search string!"
  else
    locate "$1" | grep -vi .snapshots
  fi

}

man_print() {
  MANUALS="${HOME}/Documents/Naslag - Linux - Manuals/"
  APP="$1"
  FILE="man-${APP}.txt"
  
  if [ -z "$1" ]
  then
    printf "You need to add a search string!"
  else
    man "$APP" > "$MANUALS$FILE" 
    cat "$MANUALS$FILE"
  fi
}

# ARCHIVE EXTRACTION
# usage: ex <file>
ex ()
{
  if [ -f "$1" ] ; then
    case $1 in
      *.tar.bz2)   tar xjf "$1"   ;;
      *.tar.gz)    tar xzf "$1"   ;;
      *.bz2)       bunzip2 "$1"   ;;
      *.rar)       unrar x "$1"   ;;
      *.gz)        gunzip "$1"    ;;
      *.tar)       tar xf "$1"    ;;
      *.tbz2)      tar xjf "$1"   ;;
      *.tgz)       tar xzf "$1"   ;;
      *.zip)       unzip "$1"     ;;
      *.Z)         uncompress "$1";;
      *.7z)        7z x "$1"      ;;
      *.deb)       ar x "$1"      ;;
      *.tar.xz)    tar xf "$1"    ;;
      *.tar.zst)   unzstd "$1"    ;;
      *)           echo "'$1' cannot be extracted via ex()" ;;
    esac
  else
    printf '..%s..' "This file (" "$1" ") is not a valid one."
  fi
}

app-info() {
  CLIINFO="${HOME}/temp/"

  if [[ -n "$1" ]] ; then
    echo "$1"

    # create cheatsheet
    #cheatsh "$1" > "$CLIINFO"/"$1"-cheatsheet.txt
    curl -m 10 "http://cheat.sh/${1}" > "$CLIINFO"/"$1"-cheatsheet2.txt

    # create manpage
    man "$1" > "$CLIINFO"/"$1"-manpage.txt

    # create info
    info "$1" > "$CLIINFO"/"$1"-info.txt

    # create tldr
    tldr "$1" > "$CLIINFO"/"$1"-tldr.txt

  else
    echo "No parameter provided."
  fi

}

