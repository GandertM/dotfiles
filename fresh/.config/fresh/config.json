{
  "version": 2,
  "theme": "dark",
  "editor": {
    "completion_popup_auto_show": true,
    "whitespace_tabs_leading": false,
    "whitespace_tabs_inner": false
  },
  "file_explorer": {
    "show_hidden": true,
    "show_gitignored": true
  },
  "file_browser": {
    "show_hidden": true
  },
  "lsp": {
    "bash": {
      "enabled": true,
      "auto_start": true,
      "process_limits": {
        "max_memory_percent": 50,
        "max_cpu_percent": 90,
        "enabled": true
      }
    }
  }
}